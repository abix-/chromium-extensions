{
  "scripts": {
    "build": "powershell ./prepare_extension.ps1",
    "format": "prettier --write . --ignore-path .prettierignore",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --experimental-vm-modules ./node_modules/.bin/jest"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/chrome": "^0.1.40",
    "@types/jasmine": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/jquery": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "eslint": "^10.0.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "esm": "^3.2.25",
    "husky": "^9.1.7",
    "jasmine": "^6.2.0",
    "jasmine-ts": "^0.4.0",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "rollup-plugin-commonjs": "^10.1.0",
    "rollup-plugin-typescript2": "^0.37.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "jquery": "^4.0.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.ts": [
      "npm run lint:fix",
      "git add"
    ],
    "*.{json,md,html,css}": [
      "npm run format",
      "git add"
    ],
    "build/**/*": "ignore"
  },
  "type": "module"
}
