{
  "manifest_version": 3,
  "name": "YouTube Zoom & Pan - ChatGPT",
  "version": "1.1",
  "description": "Zoom and pan YouTube videos using keyboard shortcuts and mouse wheel integration.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
